# =============================================================================
# Copy to `.env` and fill in values:  cp .env.example .env
# =============================================================================

# --- App ---------------------------------------------------------------------
PORT=8080
MONGO_ID=mongodb://127.0.0.1:27017/your-db
JWT_SECRET=change-me-long-random-string

# --- Storage (local = ./public/uploads; s3 = set bucket + keys) --------------
STORAGE_TYPE=local
# STORAGE_TYPE=s3
# AWS_REGION=
# S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=

# --- Subtitles: Silero VAD + speech-only Whisper (optional) -----------------
# Set to 1 to run Silero VAD (Python + torch); requires SILERO_PYTHON venv with requirements-vad.txt (shared with DUBBING_USE_SILERO_VAD)
# SUBTITLE_USE_SILERO_VAD=0
# full_audio (default) = Whisper on full file, then drop cues mostly in VAD silence (best text quality)
# clips = transcribe only VAD speech windows (best silence alignment, weaker text)
# SUBTITLE_VAD_TRANSCRIBE_MODE=full_audio
# Min fraction of a cue’s duration that must overlap VAD speech to keep it (0–1)
# SUBTITLE_VAD_MIN_SPEECH_OVERLAP=0.35
# SILERO_PYTHON=/path/to/backend/.venv-vad/bin/python
# SILERO_VAD_SCRIPT=/absolute/path/to/backend/scripts/silero_vad_timeline.py
# SILERO_VAD_THRESHOLD=0.45
# SILERO_VAD_MIN_SPEECH_MS=300
# SILERO_VAD_MIN_SILENCE_MS=200
# SILERO_VAD_SPEECH_PAD_MS=100
# Extra merge of speech intervals before Whisper clips (Python already merged in script)
# SILERO_VAD_MERGE_GAP_SEC=0.05
# Override Python script merge gap (ms); omit for script default (200)
# SILERO_VAD_PYTHON_MERGE_GAP_MS=
# SILERO_VAD_MIN_OUTPUT_SPEECH_MS=200
# SILERO_VAD_EXTRA_PAD_MS=40
# SILERO_VAD_NEG_THRESHOLD=
# ASR for VAD clips: whisper only for now
# SUBTITLE_ASR_PROVIDER=whisper

# --- Dubbing: required APIs --------------------------------------------------
# Google AI (Gemini): same key as subtitles / other Gemini calls — GOOGLE_API_KEY is checked first
GOOGLE_API_KEY=
# Optional separate key for dubbing only if you want to override:
# GEMINI_API_KEY=
# Optional model override (default gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash
# Optional: Inworld dubbing voice pick only (defaults to GEMINI_MODEL / gemini-2.0-flash)
# INWORLD_VOICE_SELECTION_MODEL=gemini-2.0-flash

OPENAI_API_KEY=
# Translation, voice picking, OpenAI TTS — not used for dubbing ASR
ELEVENLABS_API_KEY=
# Source separation (vocals/background) when Replicate is not set; also ElevenLabs TTS
REPLICATE_API_TOKEN=
# Optional: Demucs / separation on Replicate (see sourceSeparationUtils.js)

# --- Dubbing: TTS provider ----------------------------------------------------
# auto | openai | inworld | smallest | elevenlabs | sarvam | gemini
# gemini: Gemini 3.1 Flash TTS (uses GOOGLE_API_KEY / GEMINI_API_KEY; keeps [audio tags] in translated text)
DUBBING_TTS_PROVIDER=auto
OPENAI_TTS_MODEL=tts-1
# GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview

# --- Inworld TTS / STT (when using Inworld path) -----------------------------
INWORLD_API_KEY=
# INWORLD_TTS_URL=https://api.inworld.ai/tts/v1/voice
# INWORLD_TTS_MODEL=inworld-tts-1.5-max
# INWORLD_DEFAULT_VOICE=Jason
# INWORLD_FORCE_VOICE_ID=
# INWORLD_SPEAKING_RATE=1
# INWORLD_TEMPERATURE=1
# INWORLD_TIMESTAMP_TYPE=WORD
# INWORLD_APPLY_TEXT_NORMALIZATION=ON
# INWORLD_VOICES_LIST_URL=https://api.inworld.ai/tts/v1/voices
# INWORLD_VOICES_FILTER=language=en
# INWORLD_VOICES_NO_FILTER=0
# INWORLD_STT_URL=https://api.inworld.ai/stt/v1/transcribe
# INWORLD_STT_MODEL=groq/whisper-large-v3
# INWORLD_STT_LANGUAGE=

# --- Smallest.ai Waves (when using smallest path) ---------------------------
SMALLEST_API_KEY=
# SMALLEST_WAVES_MODEL=lightning
# SMALLEST_DEFAULT_VOICE=emily
# SMALLEST_FORCE_VOICE_ID=
# SMALLEST_SAMPLE_RATE=24000
# SMALLEST_SPEED=1
# SMALLEST_LANGUAGE=en
# SMALLEST_CONSISTENCY=0.5
# SMALLEST_SIMILARITY=0.5
# SMALLEST_ENHANCEMENT=1

# --- Dubbing: timing & translation quality ----------------------------------
# Max speed-up when TTS is longer than the segment (0.5–2.0, default 1.5)
DUBBING_MAX_ATEMPO=1.5
# Optional stricter cap when target is Hindi-like (e.g. 1.0)
# DUBBING_MAX_ATEMPO_HI=

# Optional: shift segments when silencedetect on vocals disagrees with model (legacy; off by default for Gemini)
# DUBBING_TIMELINE_CALIBRATE_ON=0
# DUBBING_TIMELINE_SILENCE_NOISE_DB=-35
# DUBBING_TIMELINE_SILENCE_MIN_SEC=0.35

# VAD_ENABLE / DUBBING_USE_SILERO_VAD alone do NOT post-filter Gemini dubbing transcripts (that used to drop the opening line).
# To run Silero overlap refine after Gemini, set BOTH VAD_ENABLE=1 (or DUBBING_USE_SILERO_VAD=1) AND:
# DUBBING_SILERO_REFINE_AFTER_GEMINI=1
# VAD_ENABLE=0
# DUBBING_USE_SILERO_VAD=0
# DUBBING_SILERO_REFINE_AFTER_GEMINI=0
# Optional; falls back to SUBTITLE_VAD_MIN_SPEECH_OVERLAP then 0.35
# DUBBING_VAD_MIN_SPEECH_OVERLAP=

# Inworld STT per-segment voice profile (extra API cost)
# DUBBING_INWORLD_STT_VOICE_PROFILE=0
# DUBBING_INWORLD_STT_VOICE_PROFILE_MAX_SEGMENTS=0
# INWORLD_STT_VOICE_PROFILE_TOP_N=5

# English Inworld bracket tags; set to "off" to disable
# DUBBING_TTS_BRACKET_ALLOWLIST=
# DUBBING_VOCAL_STYLE_ALLOWLIST=

# Save dubbing artifacts locally for debugging (optional path)
# DUBBING_LOCAL_OUTPUT_DIR=

# --- Lip-sync (Wav2Lip) — stronger “talking head” match to dubbed audio -------
# Off by default; enable only if Wav2Lip is installed
LIPSYNC_ENABLED=0
LIPSYNC_PROVIDER=local
# PYTHON_BIN=python3
# WAV2LIP_DIR=/absolute/path/to/Wav2Lip
# WAV2LIP_CHECKPOINT=/absolute/path/to/wav2lip_gan.pth
# WAV2LIP_FACE_DET_BATCH=
# WAV2LIP_PADS=0,10,0,0
# WAV2LIP_BOX=0,0,0,0
# LIPSYNC_TIMEOUT_MS=1800000
# Fail dub job if lip-sync errors (default: fall back to plain mux)
# LIPSYNC_STRICT=0

# --- Billing: Dodo Payments (subscriptions + webhooks) -----------------------
# API key from Dodo dashboard; used for checkout session creation
# DODO_PAYMENTS_API_KEY=
# Webhook signing secret (Developer → Webhooks)
# DODO_PAYMENTS_WEBHOOK_KEY=
# test_mode | live_mode (default live_mode)
# DODO_PAYMENTS_ENVIRONMENT=test_mode
# Redirect after checkout (success/cancel handled by Dodo UI)
# After Dodo hosted checkout, redirect here (match your frontend origin + path)
# DODO_CHECKOUT_RETURN_URL=http://localhost:3000/billing/success
# DODO_CHECKOUT_RETURN_URL=https://yourapp.com/billing/success
#
# Optional: upsert PlanCatalog rows on server boot (JSON array)
# Example ~10 min dubbing/mo at 5 credits/min => 50 credits
# DODO_PLAN_CATALOG_JSON=[{"key":"premium_monthly","displayName":"Premium","interval":"monthly","dodoProductId":"YOUR_DODO_SUBSCRIPTION_PRODUCT_ID","creditsPerPeriod":50,"version":1,"isActivePublic":true,"sortOrder":10}]
